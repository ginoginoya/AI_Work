# --- LM Studio API 設定 ---
# 預設為本地端 LM Studio 的位址
LLM_API_URL=http://localhost:1234/v1/chat/completions

# 使用的模型名稱 (須與 LM Studio 載入的一致)
LLM_MODEL_NAME=gemma-4-e4b-it-text-only


# --- FastAPI 伺服器設定 ---
# 0.0.0.0 代表允許區網內的所有裝置 (如 iPad) 連線
SERVER_HOST=0.0.0.0
SERVER_PORT=8000


# --- 資料庫設定 ---
# 向量資料庫儲存的路徑
CHROMA_DB_PATH=./my_fatek_db
COLLECTION_NAME=plc_manuals
